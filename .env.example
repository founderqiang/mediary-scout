# ─────────────────────────────────────────────────────────────────────────
# docker compose 自部署:多数项有默认或在「设置」页配,通常无需改本文件。
#   docker compose up -d  →  http://<host>:3000  →  设置页扫码连 115 即用。
# compose 已自动设 MEDIA_TRACK_POSTGRES_URL / PANSOU_BASE_URL / adapters。
# ─────────────────────────────────────────────────────────────────────────

# Required runtime configuration
# Postgres 连接串(SQLite 开发库已淘汰)。compose 部署自动指向自带 postgres;
# 非 compose 本机跑时才需手填,如 postgres://user:pass@localhost:5432/mediatrack
MEDIA_TRACK_POSTGRES_URL=
# TMDB v4 read token —— 可留空:默认经作者 CF Worker 代理开箱即用,
# 想用自己额度更稳可在「设置」页填或填这里。
TMDB_READ_TOKEN=
# Web search uses deterministic demo candidates by default.
# Set to "tmdb" only when you want browser searches to call TMDB (compose 默认 tmdb)。
MEDIA_TRACK_SEARCH_PROVIDER=demo
MEDIA_TRACK_DEMO_SEED=1
MEDIA_TRACK_DEFAULT_QUALITY=4K
# Leave empty so the Type 2 workflow creates the canonical
# "Title (Year)/Season N" directory itself under MEDIA_TRACK_TV_PARENT_CID.
MEDIA_TRACK_DEFAULT_TV_STORAGE_DIRECTORY_ID=
# Parent for workflow-created show directories. Use TV_SHOWS_CID in
# production; falls back to MEDIA_TRACK_115_TEST_ROOT_CID in development.
MEDIA_TRACK_TV_PARENT_CID=
# Worker adapters default to fake/no-side-effect mode. Set pansou only when the
# worker is allowed to call the real resource provider. Set storage to "115"
# only with PAN115_COOKIE plus MEDIA_TRACK_115_TEST_ROOT_CID or write scopes.
MEDIA_TRACK_WORKFLOW_ADAPTER=fake
MEDIA_TRACK_AGENT_ADAPTER=fake
MEDIA_TRACK_STORAGE_ADAPTER=fake
MEDIA_TRACK_WORKER_SECRET=
# Default public PanSou service. Replace this with your own deployment URL if you self-host.
PANSOU_BASE_URL=https://so.252035.xyz
# Your authenticated 115 cookie string
# IMPORTANT: Wrap in double quotes! The cookie contains semicolons which
# break shell parsing when loaded via `source .env`.
PAN115_COOKIE=""
MEDIA_TRACK_115_TEST_ROOT_CID=
MEDIA_TRACK_115_WRITE_SCOPE_CIDS=
MEDIA_TRACK_115_PROTECTED_CIDS=

# Optional model adapter for structured agent nodes.
# Keep the real API key in local env only; never commit it.
XIAOMI_MIMO_API_KEY=
XIAOMI_MIMO_BASE_URL=https://token-plan-sgp.xiaomimimo.com/v1
# Default in code is mimo-v2.5-pro; confirm the model id your token plan exposes.
XIAOMI_MIMO_MODEL_ID=mimo-v2.5-pro

# Required 115 directory targets
# Directory shape:
# CLAWD_MEDIA_ROOT_CID
# ├── MOVIES_CID
# ├── TV_SHOWS_CID
# └── ANIME_CID
#
# These are parent directory CIDs, not final landing directories.
CLAWD_MEDIA_ROOT_CID=
# Parent for movie leaf directories: 电影名 (年份)
MOVIES_CID=
# Parent for show directories: 剧名 (年份) -> Season N
TV_SHOWS_CID=
# Parent for anime directories: 动漫名 (年份) -> Season N
ANIME_CID=
