{
  "name": "media-track",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build:workflow": "tsc --project packages/workflow/tsconfig.json",
    "dev:web": "npm run build:workflow && next dev apps/web --turbopack",
    "build:web": "npm run build:workflow && next build apps/web",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "devDependencies": {
    "@types/node": "^22.12.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "playwright": "^1.60.0",
    "typescript": "^5.9.0",
    "vitest": "^4.0.0"
  },
  "dependencies": {
    "@ai-sdk/openai-compatible": "^2.0.48",
    "ai": "^6.0.201",
    "lucide-react": "^1.17.0",
    "next": "^16.2.9",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
