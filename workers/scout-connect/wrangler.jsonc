{
  "name": "scout-connect",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-01",
  "workers_dev": false,
  "routes": [{ "pattern": "mediaryconnect.app", "custom_domain": true }],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "scout-connect",
      "database_id": "493fb312-2301-4a85-a22f-15e68460ed98"
    }
  ],
  "vars": {
    "CONNECT_ROOT_DOMAIN": "mediaryconnect.app"
  }
}
